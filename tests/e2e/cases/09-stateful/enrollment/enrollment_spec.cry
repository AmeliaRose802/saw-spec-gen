// Cryptol model for enroll_key (whole-object post-state, heterogeneous
// mixed-width struct with implicit padding).
//
// The EnrollmentKey object is a `uint8_t engaged` flag (offset 0) next
// to a naturally aligned `int64_t createdAt` field (offset 8). The 7
// bytes of padding between them are not part of the Cryptol value; the
// named `llvm_struct` allocation leaves them unconstrained while still
// giving SAW typed i8/i64 memory cells.
//
//   --out-buffer-param k=struct:EnrollmentKey
//   --cryptol-fn-out   k=enroll_key_post
//
// SAW allocates the object as `llvm_struct "struct.EnrollmentKey"` and
// presents the pre-state `k_pre` as the Cryptol tuple ([8],[64]) —
// `engaged` then `createdAt`.

module enrollment_spec where

// (engaged, createdAt) — mirrors the typed fields in order.
type Key = ([8], [64])

// Post-state: engaged kept, createdAt overwritten with 42.
enroll_key_post : Key -> Key
enroll_key_post (engaged, _) = (engaged, 42)

// Return value: report the original engaged byte.
enroll_key_ret : Key -> [32]
enroll_key_ret (engaged, _) = zero # engaged
