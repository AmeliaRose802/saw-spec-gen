#!/usr/bin/env bash
# Pre-commit hook: reject commits that introduce or modify files exceeding
# the non-whitespace line limit (default 500). Activate this hook once with:
#
#     git config core.hooksPath .githooks
#
set -e

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

# Collect staged additions/modifications (not deletions).
staged=()
while IFS= read -r f; do
    [ -n "$f" ] && staged+=("$f")
done < <(git diff --cached --name-only --diff-filter=AM)

if [ "${#staged[@]}" -eq 0 ]; then
    exit 0
fi

exec bash scripts/check-line-count.sh "${staged[@]}"
