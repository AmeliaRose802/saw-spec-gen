// Cryptol spec for stamp_header.
//
// The function writes v into all 4 header bytes, zeros the 16 body
// bytes, and returns 20 bytes total.  The trailing [16][8] parameter
// is the pre-call state of the body field (unused here because the
// function writes every byte deterministically).
//
// The struct is 20 bytes (> 16-byte sret threshold on System V AMD64 ABI)
// so it is returned via a hidden sret pointer on both Linux and MSVC.

stamp_header_spec : [8] -> [16][8] -> [20][8]
stamp_header_spec v _pre = [v, v, v, v] # zero
