// Cryptol spec for the async add_one demo.
//
// `add_one_spec` is the mathematical contract for the async
// function: `add_one(x).await == x + 1`.
//
// The SAW proof targets the coroutine resume function — the LLVM
// function that rustc emits for the body of `async fn add_one`. It
// returns `Poll<u32>`, laid out by rustc as `{ i32 disc, i32 val }`,
// so the SAW `llvm_return` is `(0, add_one_spec x)` (discriminant 0
// = Ready).

add_one_spec : [32] -> [32]
add_one_spec x = x + 1
